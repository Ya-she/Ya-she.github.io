  "results": {
    "A": {
      "name": "The Wannabe Dry Cleaner",
      "emoji": "🧴",
      "description": "You treat your laundry like it's going to The Louvre. Every care label is a sacred text. You have Googled 'can I hand wash cashmere' no fewer than 47 times. Your washing machine is for other people. You're not other people.",
      "traits": [
        "Label Scholar",
        "Fabric Whisperer",
        "Overthinking Champion"
      ]
    },
    "B": {
      "name": "The Iron Hero",
      "emoji": "👔",
      "description": "You iron your socks. You iron your tea towels. You once ironed a paper bag 'just to see.' You find ironing deeply meditative and you have opinions about steam pressure that no one asked for and yet you will share them.",
      "traits": [
        "Steam Enthusiast",
        "Crease Assassin",
        "Secretly Loves Chores"
      ]
    },
    "C": {
      "name": "The Chaotic Hero",
      "emoji": "🌀",
      "description": "Everything goes in. One setting. One prayer. The reds, the whites, the wool jumper, the shoes — in they go. Somehow nothing has been ruined. You call this strategy. Everyone else calls it recklessness. You call them cowards.",
      "traits": [
        "Zero Regrets",
        "60°C Loyalist",
        "Chaos Gremlin"
      ]
    },
    "D": {
      "name": "The Hand-Wash Try-Hard",
      "emoji": "🫧",
      "description": "You have a dedicated basin. A special soap from a small French village. You believe machines are barbaric and your clothes agree. You know what 'gentle agitation' means and you use it in normal conversation.",
      "traits": [
        "Basin Devotee",
        "Anti-Machine",
        "Delicate Soul"
      ]
    },
    "E": {
      "name": "The ADHD Procrastinator",
      "emoji": "🧠",
      "description": "The laundry has been in the machine since Tuesday. You rewashed it three times because you forgot. You own 60 pairs of socks as a coping mechanism and you are still — somehow — out of clean socks.",
      "traits": [
        "Rewash Queen",
        "Sock Hoarder",
        "Tuesday is Relative"
      ]
    },
    "F": {
      "name": "The Laundry Scientist",
      "emoji": "📋",
      "description": "You have a colour-coded sorting system. A specific detergent for each fabric type. A laminated washing schedule. A spreadsheet. You don't just do laundry — you optimise it. Everyone in your house is both grateful and slightly scared.",
      "traits": [
        "Spreadsheet Brain",
        "Sorting Genius",
        "Scarily Organised"
      ]
    },
    "G": {
      "name": "The Eco Warrior",
      "emoji": "🌿",
      "description": "20 degrees only. Always. You make your own detergent from nuts and good intentions. You line-dry in January. You have a look — a very specific look — for people who use a tumble dryer. They know the look.",
      "traits": [
        "Cold Water Only",
        "Nut Soap Creator",
        "Silent Judge"
      ]
    },
    "H": {
      "name": "The Dry Clean Only Denier",
      "emoji": "💸",
      "description": "You see 'dry clean only' and think: challenge accepted. You have ruined 11 jumpers. You remain completely confident. 'It's fine,' you say, holding a shrunken cashmere that now fits a chihuahua. 'It's fine.'",
      "traits": [
        "Label Rebel",
        "11 Jumpers Down",
        "Eternal Optimist"
      ]
    },
    "I": {
      "name": "The Surrenderer",
      "emoji": "🏳️",
      "description": "You have not done laundry since 2019. You send it to a service, a parent, a partner, or you just buy new clothes when things get bad enough. Laundry is someone else's problem. You have made peace with this.",
      "traits": [
        "Delegation Expert",
        "New Clothes Strategist",
        "Zero Regrets"
      ]
    },
    "J": {
      "name": "The Label Ignorer",
      "emoji": "🕵️",
      "description": "You cut out every care label because they're 'scratchy and annoying.' You now have no idea what anything is made of. Is this wool? Polyester? Mystery fabric from a mystery land? Doesn't matter. In it goes.",
      "traits": [
        "Label Executioner",
        "Mystery Fabric Fan",
        "Living Dangerously"
      ]
    },
    "K": {
      "name": "The Midnight Launcher",
      "emoji": "🌙",
      "description": "It is 11pm. Somehow, again, you are only now starting laundry. You don't know how this keeps happening. The machine will finish at 1am. This is fine. This is a normal life. You'll deal with it tomorrow. Or Thursday.",
      "traits": [
        "Night Owl Washer",
        "11pm Every Time",
        "Tomorrow's Problem"
      ]
    },
    "L": {
      "name": "The Cold Water Cultist",
      "emoji": "🧊",
      "description": "Cold water for EVERYTHING. Your whites are grey and your colours are faded but your carbon footprint is thriving. You will explain the benefits of cold washing to anyone within earshot, solicited or not. The planet thanks you. Your shirts less so.",
      "traits": [
        "Cold Water Evangelist",
        "Climate Champion",
        "Grey Whites Haver"
      ]
    }
