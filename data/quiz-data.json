      "biodiversity_credits",
      "redd_plus"
    ]
  },
  "results": {
    "nbs": {
      "name": "Nature-based Solution",
      "subtitle": "The all-rounder. Please do not ask for a definition.",
      "badge": "The Undefinable Darling",
      "palette": ["#3D6F2C", "#B7D698"],
      "description": "You are the policy world's favorite umbrella term. You do everything — flood protection, carbon, biodiversity, urban cooling, community wellbeing — which is mostly great, except nobody can agree on what you actually are. You thrive in funding proposals and IUCN side events. You are beloved, slightly vague, and doing your best.",
      "whyItFits": [
        "You promise co-benefits without specifying whose.",
        "You are cited in every policy paper and defined in none.",
        "You are what people mean when they say 'win-win.'"
      ]
    },
    "nature_as_infrastructure": {
      "name": "Nature as Infrastructure",
      "subtitle": "NbS's hipper, slightly unhinged younger sibling.",
      "badge": "The Engineer in a Field Jacket",
      "palette": ["#49715A", "#A9C9B5"],
      "description": "You took one look at NbS and said 'but what if we quantified it harder?' You reframe ecosystems as service-delivery assets on municipal balance sheets. You are beloved by World Bank reports and confusing at dinner parties. Mangroves are your levees. Wetlands are your stormwater utility. Nature works for you, literally.",
      "whyItFits": [
        "You turn ecosystems into line items.",
        "You speak fluent procurement and fluent mycelium.",
        "You are mostly a pitch deck in a trench coat."
      ]
    },
    "carbon_offset_biodiversity": {
      "name": "Carbon Offset with Biodiversity Co-benefit",
      "subtitle": "They say you can do it all. You cannot.",
      "badge": "The Shiny Toy",
      "palette": ["#6B8F3E", "#D4E4A8"],
      "description": "Everyone wants to play with you. You promise carbon neutrality AND charismatic megafauna in one tidy credit. You are featured in airline ads and sustainability reports. The problem is if anyone looks too closely they notice the additionality is vibes and the biodiversity metric is a bird list from 2014. You remain very popular.",
      "whyItFits": [
        "You bundle two goods to distract from one problem.",
        "You photograph extremely well.",
        "Verification is a personal journey, not a requirement."
      ]
    },
    "ccs": {
      "name": "Carbon Capture & Storage",
      "subtitle": "The techno-fix bachelor who refuses to go to therapy.",
      "badge": "The Refused Retrofit",
      "palette": ["#5A5E6B", "#BFC4CE"],
      "description": "You are the engineering-school golden child who thinks we can drill our way out of this. You have a PowerPoint and three pilot projects, two of which are delayed. Fossil fuel companies love you. You avoid the words 'demand reduction' the way a cat avoids water. You will, you insist, scale any day now.",
      "whyItFits": [
        "You prefer a technical fix to a political one.",
        "Your pilot phase has a pilot phase.",
        "You are somehow both the future and 2007."
      ]
    },
    "pes": {
      "name": "Payments for Ecosystem Services",
      "subtitle": "Paying nature to show up to work.",
      "badge": "The HR Department of the Biosphere",
      "palette": ["#4D8C55", "#D5EDC8"],
      "description": "You look at a watershed and see a contractor. You believe rural communities will steward landscapes if you wire them the right monthly transfer. Sometimes this works. Sometimes it dispossesses people from commons they already managed for free. You mean well, mostly, and you have very good spreadsheets.",
      "whyItFits": [
        "You convert stewardship into a service contract.",
        "You love a pilot in Costa Rica.",
        "You ask 'what would motivate a landowner?' instead of 'who owns the land?'"
      ]
    },
    "biodiversity_credits": {
      "name": "Biodiversity Credits",
      "subtitle": "Carbon offsets' ambitious cousin, already under scrutiny.",
      "badge": "The Sequel Nobody Asked For",
      "palette": ["#8E7B46", "#EBDDB6"],
      "description": "You are new, you are glossy, and the ink on your methodology is still wet. Investors are excited. Indigenous and local communities are asking sharp questions you do not want to answer. You claim to make biodiversity 'investable,' which is either the future of conservation or a category error, depending on who you ask at the conference.",
      "whyItFits": [
        "You treat habitat as a tradable unit.",
        "Your methodology is 'emerging' (unfinished).",
        "You were launched at COP with a sizzle reel."
      ]
    },
    "redd_plus": {
      "name": "REDD+",
      "subtitle": "The aging celebrity with a complicated colonial past.",
      "badge": "The Veteran",
      "palette": ["#2F7A5D", "#9FD7BB"],
      "description": "You have been around since Bali 2007. You were going to end deforestation. Instead you generated academic careers, a vast compliance industry, and several lawsuits about overlapping land claims. You are still here, reformulating yourself for the voluntary market. You carry the entire history of forest carbon in one tired acronym.",
      "whyItFits": [
        "You have a longer publication record than most professors.",
        "You are constantly being 'reformed.'",
        "You remember when 'permanence' was still a debate, not a disclaimer."
      ]
    }
  },
